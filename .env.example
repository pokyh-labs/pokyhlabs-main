# Server
PORT=3001
HOST=127.0.0.1
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (SQLite — no server needed)
SQLITE_PATH=./data/database.sqlite

# JWT (generate with: cd backend && npm run generate-secrets)
JWT_SECRET=CHANGE_ME_64_BYTE_HEX
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_BYTE_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=your-app-name
JWT_AUDIENCE=your-app-name-api

# Encryption key for API tokens (generate with: cd backend && npm run generate-secrets)
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX

# Upload
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads

# Logs (optional — defaults to ./backend/logs)
# LOG_PATH=./logs

# Admin (initial setup — run: cd backend && npm run add-admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# Cloudflare (optional — configure via admin dashboard)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# Frontend / Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001/api
BACKEND_URL=http://localhost:3001

# Vite dev server port (optional, default: 5173)
# VITE_DEV_PORT=5173

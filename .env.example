# ── Server ────────────────────────────────────────────────────
# Single port — Next.js frontend + Express backend run together in server.js
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (SQLite — no external server needed) ─────────────
SQLITE_PATH=./data/database.sqlite

# ── JWT (run: npm run generate-secrets to get safe values) ────
JWT_SECRET=CHANGE_ME_64_BYTE_HEX
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_BYTE_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption key (run: npm run generate-secrets) ────────────
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX

# ── Upload ────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=15
UPLOAD_PATH=./uploads

# ── Logs (optional — defaults to ./backend/logs) ─────────────
# LOG_PATH=./logs

# ── Admin first-run setup ─────────────────────────────────────
# Only used by: npm run add-admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Frontend / Next.js ────────────────────────────────────────
# NEXT_PUBLIC_API_URL is used client-side; BACKEND_URL is used server-side (SSR).
# Both default to http://localhost:$PORT if not set.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
BACKEND_URL=http://localhost:3000

# ── Docker MySQL (only needed when using docker-compose) ──────
# DB_NAME=pokyhlabs
# DB_USER=pokyhlabs_user
# DB_PASSWORD=CHANGE_ME_DB_PASSWORD
# DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD   ← required, no default

# ── Cloudflare (optional — configure via admin dashboard) ─────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TOKEN=

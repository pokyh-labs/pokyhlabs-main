# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pokyhlabs
DB_USER=pokyhlabs_user
DB_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
DB_ROOT_PASSWORD="CHANGE_ME_ROOT_PASSWORD"

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_64_BYTE_HEX
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_BYTE_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for API tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX

# Upload
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads

# Admin (initial setup — run: npm run add-admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# Cloudflare (optional — configure via admin dashboard)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
BACKEND_URL=http://localhost:3001

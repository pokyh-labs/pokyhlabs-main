{
  "name": "pokyhlabs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix backend",
    "dev": "node server.js",
    "dev:frontend": "next dev",
    "dev:backend": "npm run dev --prefix backend",
    "build": "next build && npm run build --prefix backend",
    "build:backend": "npm run build --prefix backend",
    "start": "node server.js",
    "start:backend": "npm run start --prefix backend",
    "add-admin": "npm run add-admin --prefix backend",
    "generate-secrets": "npm run generate-secrets --prefix backend",
    "security-test": "npm run security-test --prefix backend"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "dotenv": "^17.4.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "typescript": "^5"
  }
}

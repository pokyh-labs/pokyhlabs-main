# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
# If DB_HOST is set, the app uses a network database (default dialect: postgres).
# If DB_HOST is empty/unset, it falls back to local SQLite (SQLITE_PATH below) —
# convenient for local development.
#
# PostgreSQL (production — e.g. Dokploy):
# DB_DIALECT=postgres          # postgres (default) | mysql | mariadb
# DB_HOST=your-postgres-service-name
# DB_PORT=5432                 # default per dialect: postgres 5432, mysql 3306
# DB_NAME=pokyhlabs
# DB_USER=pokyhlabs_user
# DB_PASSWORD=change_me
#
# Connection pool (optional — sensible defaults shown):
# DB_POOL_MAX=10
# DB_POOL_MIN=0
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=10000
#
# TLS (optional — only if your Postgres requires SSL):
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false   # set false for self-signed/internal certs

# SQLite fallback (used only when DB_HOST is empty — path relative to cwd, or absolute)
SQLITE_PATH=./data/database.sqlite

# JWT (generate with: npm run generate-secrets)
JWT_SECRET=CHANGE_ME_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=your-app-name
JWT_AUDIENCE=your-app-name-api

# Encryption key for API tokens (generate with: npm run generate-secrets)
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# Upload
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads

# Logs (optional — defaults to ./logs next to the backend directory)
# LOG_PATH=/var/log/pokyhlabs

# Admin (initial setup only — run: npm run add-admin, then remove these)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Cloudflare (optional — can be configured via admin dashboard)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# Frontend origin
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ── Email (Resend SMTP) ───────────────────────────────────────────────────────
# Contact-form notifications, customer confirmations and dashboard replies are
# sent through Resend's SMTP relay. Get the API key from resend.com and verify
# the sending domain (set SPF / DKIM / DMARC DNS records at your registrar).
# If RESEND_API_KEY is empty, the app simply skips sending (form still works).
RESEND_API_KEY=
MAIL_DOMAIN=pokyh.studio
MAIL_FROM=noreply@pokyh.studio
MAIL_FROM_NAME=Pokyh Studio
# Where new-inquiry notifications are delivered:
MAIL_ADMIN=pokyhstudio@gmail.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend

# Vite dev server port (optional, default: 5173)
# VITE_DEV_PORT=5173

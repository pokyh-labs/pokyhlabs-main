# Server
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pokyhlabs
DB_USER=pokyhlabs_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log")
JWT_SECRET=CHANGE_ME_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for API tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# Upload
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads

# Admin (initial setup only - remove after first run)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Cloudflare (optional - can be set via dashboard)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TOKEN=
